# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mydatabase
DB_SSLMODE=disable

# SMTP Configuration (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=gmailpassword

# Encryption key for sensitive data at rest (AES-256-GCM).
# REQUIRED. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_random_64_hex_chars

# CORS: allowed frontend origin(s), comma-separated. Use "*" only for development.
# Example: ALLOWED_ORIGIN=https://yourapp.com,https://www.yourapp.com
ALLOWED_ORIGIN=*

# TLS (optional — for direct HTTPS without a reverse proxy).
# If not set, the server runs over plain HTTP (suitable behind nginx/traefik with TLS termination).
# TLS_CERT_FILE=/path/to/cert.pem
# TLS_KEY_FILE=/path/to/key.pem
# HTTP_PORT=8080   # port for the HTTP→HTTPS redirect server

# Application port (default: 8080; when TLS is enabled, this becomes the HTTPS port, default 8443)
# PORT=8080
